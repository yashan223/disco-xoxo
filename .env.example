# ============================================================
# DISCO XOXO — Environment Variables
# Copy this file to .env and fill in all required values.
# ============================================================

# ----------------------------
# Discord Bot
# ----------------------------
DISCORD_TOKEN=                          # Bot token from Discord Developer Portal
CLIENT_ID=                              # Discord Application Client ID
VITE_DISCORD_CLIENT_ID=                 # Required for dashboard invite link
CLIENT_SECRET=                          # Discord Application Client Secret
DISCORD_REDIRECT_URI=http://localhost:3001/auth/discord/callback

# ----------------------------
# Spotify
# ----------------------------
SPOTIFY_CLIENT_ID=                      # Spotify Application Client ID
SPOTIFY_CLIENT_SECRET=                  # Spotify Application Client Secret
SPOTIFY_REDIRECT_URI=http://localhost:3001/auth/spotify/callback
# Bot Spotify Premium account credentials (for librespot audio streaming)
SPOTIFY_BOT_USERNAME=                   # Spotify Premium account email/username
SPOTIFY_BOT_PASSWORD=                   # Spotify Premium account password

# ----------------------------
# MongoDB
# ----------------------------
MONGODB_URI=mongodb://mongo:27017/disco-xoxo

# ----------------------------
# Security
# ----------------------------
JWT_SECRET=change-me-to-a-strong-random-secret-min-32-chars
SESSION_SECRET=change-me-to-another-strong-secret-min-32-chars

# ----------------------------
# Server
# ----------------------------
PORT=3001
NODE_ENV=development
DASHBOARD_URL=http://localhost:3000
API_URL=http://localhost:3001

# ----------------------------
# Redis (rate limiting & sessions)
# ----------------------------
REDIS_URL=redis://redis:6379

# ----------------------------
# Logging
# ----------------------------
LOG_LEVEL=info
